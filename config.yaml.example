model: gpt-5.4                   # LLM model (any LiteLLM-supported provider)
language: en                     # Wiki output language
pageindex_threshold: 20          # PDF pages threshold for PageIndex-style long-doc routing
ingest_gate:
  enabled: false                 # Enable pre-ingest scoring gate before files enter raw/
  pass_threshold: 75             # PASS if total score >= this value
  hold_threshold: 60             # HOLD if hold_threshold <= score < pass_threshold
  hard_reject_enabled: true      # Enforce hard reject flags from the scoring model
  log_all_decisions: true        # Record gate decisions to wiki/explorations + .openkb history
  allow_force_pass: true         # Allow CLI/operator override to force a pass
  allow_force_reject: true       # Allow CLI/operator override to force a reject
auto_review:
  enabled: false                 # Enable post-summary auto-review
  dry_run: true                  # Write audit log but do not modify ledger state
  kb_topic: ""                   # Optional override for topic_fit anchor; falls back to KB-default
  approve_threshold: 70          # Auto-approve when v2 total >= this AND no HOLD gates trip
  reject_threshold: 50           # Auto-reject when v2 total < this OR critical floor breached
  min_research_depth: 8          # /15 — below this triggers HOLD
  min_durability: 6              # /15 — below this triggers HOLD
  min_novelty_vs_kb: 5           # /10 — below this triggers HOLD
  min_topic_fit: 2               # /5  — below this triggers HOLD
  min_source_coverage: 8         # /15 — below this triggers HOLD
  daily_approve_budget: 15       # Soft cap on daily auto-approvals; extras roll to HOLD
  hard_signals:
    ephemeral_patterns: [每日, 周报, 月报, 避雷, 收市, 盘前, 盘后, 晨会, 晨报, 早评, 夜报]
    transcript_patterns: [对话, 纪要, 路演, 电话会, 调研纪要, 访谈, 录音]
    news_patterns: [快讯, 速报, 热点, 突发]
  overlap:
    reject_threshold: 0.80       # Jaccard with any existing wiki page above this → reject
    hold_threshold: 0.60         # 0.60 ≤ overlap < 0.80 → hold for human merge decision
    top_k: 5                     # Keep this many top hits in the audit log
    min_report_score: 0.30       # Below this, hits are not reported (max_overlap still tracked)
wire_api: responses              # gpt-5 models prefer responses; others may use chat_completions
base_url: ""                     # Optional OpenAI-compatible gateway URL, e.g. https://api.example.com/v1

# ---------------------------------------------------------------------------
# Entity alias enrichment (Phase 1) — feeds AkShare-backed aliases into the
# entity registry so duplicate company pages don't accumulate.
# ---------------------------------------------------------------------------
entity_enrichment:
  enabled: true
  provider_priority:
    - akshare:xueqiu
    - akshare:fallback
  symbol_index_ttl_days: 14         # cache .openkb/entity_registry/symbol_index/*.json for this long
  auto_apply_min_confidence: 0.95   # below this, suggestions need manual review
  allow_fuzzy_auto_apply: false
  rate_limit:                       # AkShare per-market throttle for alias enrichment
    cn_a_requests_per_minute: 30
    hk_requests_per_minute: 10      # HK is slow/throttled in practice
    us_requests_per_minute: 6       # US is even slower; keep conservative
    retry_backoff_seconds: [2, 5, 15]

# ---------------------------------------------------------------------------
# Market snapshot layer (Phase 2) — on-demand quote/PE/PB/market_cap cache for
# companies resolved by the entity registry. No full-market crawling.
# ---------------------------------------------------------------------------
market_data:
  enabled: true
  provider_priority:
    - akshare:xueqiu
    - akshare:fallback
  refresh:
    equity_ttl_market_hours_minutes: 30   # snapshot freshness during market hours
    equity_ttl_overnight_hours: 12        # longer TTL outside market hours
    fund_nav_ttl_hours: 24                # NAV is published once per trading day
    stale_usable_days_equity: 7           # serve cached equity quotes this long after TTL
    stale_usable_days_fund: 14            # serve cached NAV this long after TTL
  retention:
    history_months: 12                    # keep this many monthly JSONL files per symbol
    keep_raw_responses: false             # debug only; usually false
  query_agent:
    require_stale_disclaimer: true        # agent must surface a disclaimer when stale=true
