# LLM API key (required) — works with any LiteLLM-supported provider
# OpenAI:    LLM_API_KEY=sk-...
# Anthropic: LLM_API_KEY=sk-ant-...
# Gemini:    LLM_API_KEY=AIza...
LLM_API_KEY=your-key-here

# Optional for OpenAI-compatible gateways
# OPENAI_BASE_URL=https://your-gateway/v1

# Optional wire protocol override for OpenAI-compatible gateways
# gpt-5 models typically work best with the Responses API.
# OPENKB_WIRE_API=responses
